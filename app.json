{
  "expo": {
    "name": "Cal Track",
    "slug": "project-1",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Cal_Track_Icon.png",
    "scheme": "cal-track",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#003366",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "icon": "./assets/images/Cal_Track_Icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yashsinha14steam.project1"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Cal_Track_Icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bdb76473-957c-4fa5-acd5-e709332d8cc3"
      }
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/bdb76473-957c-4fa5-acd5-e709332d8cc3"
    },
    "owner": "yashsinha14s-team",
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
